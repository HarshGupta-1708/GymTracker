{
  "expo": {
    "name": "GYM TRACKER",
    "slug": "gym-tracker",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gymtracker",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.harshgupta1708.gymtracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080810",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.harshgupta1708.gymtracker",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "gymtracker",
              "host": "oauthredirect"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        }
      ],
      "versionCode": 8
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "coachApiUrl": "https://gymtracker-coach-api.onrender.com",
      "googleWebClientId": "1013071433374-5nt3jtkhhok3c1u37k6qrlsna32doa8j.apps.googleusercontent.com",
      "googleAndroidClientId": "1013071433374-tbuplbi4egicmjsogurlfv9elkhpp1s4.apps.googleusercontent.com",
      "eas": {
        "projectId": "4ee12947-5aac-446c-b5e9-b65a8ff60249"
      }
    }
  }
}
