{
  "expo": {
    "name": "GYM TRACKER",
    "slug": "gym-tracker",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gymtracker",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.harshgupta1708.gymtracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080810",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.harshgupta1708.gymtracker",
      "permissions": [
        "INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "gymtracker",
              "host": "oauthredirect"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        }
      ],
      "versionCode": 5
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "coachApiUrl": "https://gymtracker-coach-api.onrender.com",
      "eas": {
        "projectId": "66c0e0bf-86f3-401d-9925-86dfbec070fa"
      }
    }
  }
}
