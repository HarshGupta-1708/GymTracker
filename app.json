{
  "expo": {
    "name": "GYM TRACKER",
    "slug": "gym-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gymtracker",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.harshgupta1708.gymtracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080810",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.harshgupta1708.gymtracker",
      "permissions": [
        "INTERNET"
      ],
      "versionCode": 3
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "66c0e0bf-86f3-401d-9925-86dfbec070fa"
      }
    }
  }
}
