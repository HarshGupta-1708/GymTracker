# Copy to .env and fill values (never commit .env)

PORT=3001
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
COACH_DAILY_LIMIT=20

# Paste full Firebase service account JSON as ONE line (from Firebase Console)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: allow demo-user header from app (set true for testing)
ALLOW_DEMO_COACH=false

# Dev only — skip Firebase if true (NEVER in production)
ALLOW_INSECURE_DEV=false
