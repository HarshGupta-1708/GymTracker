# Google OAuth Configuration
# Get these values from Firebase Console → Project Settings → Web App

# Google OAuth Client IDs
# WEB client ID (required for all platforms — used in the browser-based OAuth flow)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# ANDROID client ID (required for Android emulator + APK)
# Create in Google Cloud Console → APIs & Services → Credentials → OAuth client ID → Android
# Package name: com.harshgupta1708.gymtracker
# SHA-1: from `keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android`
# For production APK, also create one with the production SHA-1 from `eas credentials -p android`
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com

# iOS Client ID (optional, for iOS builds)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com

# AI Coach API (Render — see docs/COACH_AI_SETUP.md)
EXPO_PUBLIC_COACH_API_URL=https://gymtracker-coach-api.onrender.com
# REACT_APP_FIREBASE_API_KEY=YOUR_API_KEY
# REACT_APP_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
# REACT_APP_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
# REACT_APP_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
# REACT_APP_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
# REACT_APP_FIREBASE_APP_ID=YOUR_APP_ID
